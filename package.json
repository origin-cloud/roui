{
  "name": "roui-element",
  "version": "1.0.1",
  "description": "Roui 是一个基于 Vue 3 的组件库",
  "author": "xiamimi",
  "license": "MIT",
  "keywords": [
    "Component",
    "UI",
    "Vue3"
  ],
  "homepage": "https://github.com/origin-mumu/roui",
  "repository": {
    "type": "git",
    "url": "https://github.com/origin-mumu/roui.git"
  },
  "bugs": {
    "url": "https://github.com/origin-mumu/roui/issues"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/umd/r-element.umd.cjs",
  "module": "./dist/es/r-element.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/r-element.js",
      "require": "./dist/umd/r-element.umd.cjs"
    },
    "./dist/": {
      "import": "./dist/",
      "require": "./dist/"
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build-only && npm run move-style",
    "preview": "vite preview",
    "build-only": "run-p build-es build-umd",
    "build-umd": "vite build --config vite.umd.config.ts",
    "build-es": "vite build --config vite.es.config.ts",
    "move-style": "move-file dist/es/style.css dist/style.css",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vitepress-demo-preview/component": "^2.6.1",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "axios": "^1.13.2",
    "lodash-es": "^4.17.22",
    "shiki": "^3.20.0",
    "vue": "^3.3.4"
  },
  "peerDependencies": {
    "vue": "^3.3.4"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/vue-fontawesome": "^3.1.2",
    "@popperjs/core": "^2.11.8",
    "@rollup/plugin-json": "^6.1.0",
    "@tsconfig/node24": "^24.0.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitejs/plugin-vue-jsx": "^5.1.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "async-validator": "^4.2.5",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "~10.5.1",
    "jiti": "^2.6.1",
    "jsdom": "^27.3.0",
    "npm-run-all2": "^8.0.4",
    "postcss-comment": "^2.0.0",
    "postcss-for": "^2.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "3.6.2",
    "rollup": "^4.54.0",
    "sass": "^1.97.1",
    "typescript": "~5.9.0",
    "unplugin-vue-macros": "^1.8.1",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-eslint": "^1.8.1",
    "vitepress": "^2.0.0-alpha.15",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.1.5"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ]
}
