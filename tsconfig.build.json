{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "include": ["src/index.ts", "src/components/**/*", "src/hooks/**/*"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "target": "es2022"
  },
  "references": [
    {
      "path": "./tsconfig.config.json"
    }
  ]
}
